Cell["Dimension-Curvature Landscape", "Section",ExpressionUUID->"d8c81def-4553-4380-9d58-96effd7e62bb"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"pts", " ", "=", " ", 
      RowBox[{"DeleteCases", "[", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"lf", " ", "=", " ", 
              RowBox[{"lastFit", "[", 
               RowBox[{"data", "[", "#", "]"}], "]"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"#", ",", " ", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MatchQ", "[", 
                 RowBox[{"lf", ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"_", ",", " ", "_"}], "}"}]}], "]"}], ",", " ", 
                RowBox[{"strip", "[", 
                 RowBox[{"lf", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", " ", 
                RowBox[{"Missing", "[", "]"}]}], "]"}], ",", "\n", "        ", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"MatchQ", "[", 
                 RowBox[{"lf", ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"_", ",", " ", "_"}], "}"}]}], "]"}], ",", " ", 
                RowBox[{"strip", "[", 
                 RowBox[{"lf", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", " ", 
                RowBox[{"Missing", "[", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Last", "[", 
               RowBox[{
                RowBox[{"data", "[", "#", "]"}], "[", "\"\<VertexCounts\>\"", 
                "]"}], "]"}]}], "}"}]}], "]"}], " ", "&"}], " ", "/@", " ", 
         RowBox[{"Keys", "[", "data", "]"}]}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"_", ",", " ", "_Missing", ",", " ", "_", ",", " ", "_"}], 
          "}"}], " ", "|", " ", 
         RowBox[{"{", 
          RowBox[{"_", ",", " ", "_", ",", " ", "_Missing", ",", " ", "_"}], 
          "}"}]}]}], "]"}]}], ",", " ", 
     RowBox[{"nbins", " ", "=", " ", "7"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"lo", " ", "=", " ", 
        RowBox[{"Min", "[", 
         RowBox[{"pts", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", " ", "4"}], "]"}], "]"}], "]"}]}], ",", " ", 
       RowBox[{"hi", " ", "=", " ", 
        RowBox[{"Max", "[", 
         RowBox[{"pts", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", " ", "4"}], "]"}], "]"}], "]"}]}]}], "}"}], ",",
      "\n", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"grouped", " ", "=", " ", 
         RowBox[{"KeySort", " ", "@", " ", 
          RowBox[{"GroupBy", "[", 
           RowBox[{"pts", ",", " ", 
            RowBox[{
             RowBox[{"Clip", "[", 
              RowBox[{
               RowBox[{"Ceiling", "[", 
                RowBox[{"nbins", " ", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "4", "]"}], "]"}], " ", "-", " ", "lo"}], 
                   ")"}], "/", 
                  RowBox[{"(", 
                   RowBox[{"hi", " ", "-", " ", "lo", " ", "+", " ", "1"}], 
                   ")"}]}]}], "]"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"1", ",", " ", "nbins"}], "}"}]}], "]"}], " ", 
             "&"}]}], "]"}]}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"Legended", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"ListPlot", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Map", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Callout", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", " ", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", " ", 
                  RowBox[{"Hyperlink", "[", 
                   RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                    RowBox[{"url", "[", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], "]"}], 
                " ", "&"}], ",", " ", "#"}], "]"}], " ", "&"}], " ", "/@", 
            " ", 
            RowBox[{"Values", "[", "grouped", "]"}]}], ",", "\n", "     ", 
           RowBox[{"PlotStyle", " ", "->", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Blend", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"StandardYellow", ",", " ", "StandardRed"}], "}"}], 
                 ",", " ", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"#", " ", "-", " ", "1"}], ")"}], "/", 
                  RowBox[{"(", 
                   RowBox[{"nbins", " ", "-", " ", "1"}], ")"}]}]}], "]"}], 
               " ", "&"}], " ", "/@", " ", 
              RowBox[{"Keys", "[", "grouped", "]"}]}], ")"}]}], ",", "\n", 
           "     ", 
           RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
           RowBox[{"FrameLabel", " ", "->", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<dimension\>\"", ",", " ", "\"\<curvature\>\""}], 
             "}"}]}], ",", " ", 
           RowBox[{"Background", " ", "->", " ", "White"}], ",", "\n", 
           "     ", 
           RowBox[{"ImageSize", " ", "->", " ", "560"}], ",", " ", 
           RowBox[{
           "PlotLabel", " ", "->", 
            " ", "\"\<Dimension-Curvature Landscape\>\""}]}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"BarLegend", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"Blend", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"StandardYellow", ",", " ", "StandardRed"}], "}"}], ",",
                 " ", 
                RowBox[{"Rescale", "[", 
                 RowBox[{"#", ",", " ", 
                  RowBox[{"{", 
                   RowBox[{"lo", ",", " ", "hi"}], "}"}]}], "]"}]}], "]"}], 
              " ", "&"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"lo", ",", " ", "hi"}], "}"}]}], "}"}], ",", " ", 
           RowBox[{"LegendLabel", " ", "->", " ", "\"\<vertices\>\""}]}], 
          "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}]], "Input",ExpressionUUID->\
"28821af7-f2ff-42b5-be63-c273e895cbf9"],

Cell["Individual Characteristics", "Section",ExpressionUUID->"da2e4843-a336-4be1-b432-459f47907da7"],

