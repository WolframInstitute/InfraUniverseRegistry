Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dc", " ", "=", " ", 
     RowBox[{"dimcurvSeq", "[", 
      RowBox[{"data", "[", "exId", "]"}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", "\n", "   ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", 
        RowBox[{
         RowBox[{"DeleteCases", "[", 
          RowBox[{
           RowBox[{"MapIndexed", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"First", "[", "#2", "]"}], ",", " ", 
                RowBox[{"#1", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], "}"}], " ", "&"}], ",", 
             " ", "dc"}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"_", ",", " ", "_Missing"}], "}"}]}], "]"}], ",", " ", 
         RowBox[{"PlotStyle", " ", "->", " ", "StandardBlue"}], ",", "\n", 
         "    ", 
