Cell["Dimension-curvature trajectory (gray to red by vertices)", "Subsection",ExpressionUUID->"9f91550e-9390-4f06-9eda-611c8a1b1429"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"t", " ", "=", " ", 
     RowBox[{"trajectory", "[", 
      RowBox[{"data", "[", "exId", "]"}], "]"}]}], "}"}], ",", "\n", " ", 
   RowBox[{"Legended", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", " ", 
         RowBox[{"Line", "[", 
          RowBox[{
           RowBox[{"t", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
           RowBox[{"VertexColors", " ", "->", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Blend", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"StandardGray", ",", " ", "StandardRed"}], "}"}], ",",
                  " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
              RowBox[{"Rescale", "[", 
               RowBox[{"t", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "]"}]}], 
             ")"}]}]}], "]"}], ",", "\n", "    ", 
         RowBox[{"PointSize", "[", "0.025", "]"}], ",", " ", 
         RowBox[{"Point", "[", 
          RowBox[{
           RowBox[{"t", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
           RowBox[{"VertexColors", " ", "->", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Blend", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"StandardGray", ",", " ", "StandardRed"}], "}"}], ",",
                  " ", "#"}], "]"}], " ", "&"}], " ", "/@", " ", 
              RowBox[{"Rescale", "[", 
               RowBox[{"t", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "]"}]}], 
             ")"}]}]}], "]"}]}], "}"}], ",", "\n", "   ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<dimension\>\"", ",", " ", "\"\<curvature\>\""}], 
         "}"}]}], ",", " ", 
       RowBox[{"AspectRatio", " ", "->", " ", 
        RowBox[{"1", "/", "GoldenRatio"}]}], ",", " ", 
       RowBox[{"ImageSize", " ", "->", " ", "480"}], ",", "\n", "   ", 
       RowBox[{"Background", " ", "->", " ", "White"}], ",", " ", 
       RowBox[{"PlotLabel", " ", "->", " ", 
        RowBox[{"exId", " ", "<>", " ", "\"\< (d,K) trajectory\>\""}]}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"BarLegend", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Blend", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"StandardGray", ",", " ", "StandardRed"}], "}"}], ",", 
            " ", 
            RowBox[{"Rescale", "[", 
             RowBox[{"#", ",", " ", 
              RowBox[{"MinMax", "[", 
               RowBox[{"t", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "]"}]}], 
             "]"}]}], "]"}], " ", "&"}], ",", " ", 
         RowBox[{"MinMax", "[", 
          RowBox[{"t", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], "]"}]}], "}"}], ",",
        " ", 
       RowBox[{"LegendLabel", " ", "->", " ", "\"\<vertices\>\""}]}], "]"}]}],
     "]"}]}], "]"}]], "Input",ExpressionUUID->"8cecfddb-71ed-4815-aac2-\
4cd8a8f25c9a"],

Cell["Stability (Cauchy tail diameter)", "Subsection",ExpressionUUID->"ed1bf3c5-b68d-4c09-a54d-b0f198ff4cdc"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"p", " ", "=", " ", 
     RowBox[{
      RowBox[{"trajectory", "[", 
       RowBox[{"data", "[", "exId", "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], "}"}], ",", "\n", " ", 
   
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"EuclideanDistance", " ", "@@@", " ", 
         RowBox[{"Subsets", "[", 
          RowBox[{
           RowBox[{"p", "[", 
            RowBox[{"[", 
             RowBox[{"n0", " ", ";;"}], "]"}], "]"}], ",", " ", 
           RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n0", ",", " ", "1", ",", " ", 
         RowBox[{
          RowBox[{"Length", "[", "p", "]"}], " ", "-", " ", "1"}]}], "}"}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"Mesh", " ", "->", " ", "All"}], ",", " ", 
     RowBox[{"PlotStyle", " ", "->", " ", "StandardBlue"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "True"}], ",", " ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<n0\>\"", ",", " ", "\"\<tail diameter\>\""}], "}"}]}], ",",
      "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Cauchy tail diameter (stability score = 1/(1 + min over last \
n/3))\>\""}], ",", " ", 
     RowBox[{"ImageSize", " ", "->", " ", "480"}], ",", " ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "]"}]}], "]"}]], "Input",\
