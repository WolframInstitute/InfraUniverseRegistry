 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"q", " ", "=", " ", 
     RowBox[{"LogDifferenceQuotients", " ", "/@", " ", 
      RowBox[{
       RowBox[{"data", "[", "exId", "]"}], "[", "\"\<Growths\>\"", "]"}]}]}], 
