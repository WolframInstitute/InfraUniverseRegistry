Cell[BoxData[{
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{"Remove", "[", "\"\<Global`WolframModel\>\"", "]"}], "]"}], ";", 
  " ", 
  RowBox[{"Needs", "[", "\"\<SetReplace`\>\"", "]"}], ";"}], "\n", 
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"wmd", " ", "=", " ", 
     RowBox[{"ResourceFunction", "[", "\"\<WolframModelData\>\"", "]"}]}], 
    "}"}], ",", "\n", " ", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{"Partition", "[", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Graph", "[", 
         RowBox[{
          RowBox[{"graphOf", "[", "#", "]"}], ",", " ", 
          RowBox[{"ImageSize", " ", "->", " ", "90"}], ",", " ", 
          "graphOpts"}], "]"}], " ", "&"}], " ", "/@", "\n", "    ", 
       RowBox[{"Rest", "[", 
        RowBox[{
         RowBox[{"WolframModel", "[", 
          RowBox[{
           RowBox[{"wmd", "[", 
            RowBox[{"exId", ",", " ", "\"\<Rule\>\""}], "]"}], ",", " ", 
           RowBox[{"wmd", "[", 
            RowBox[{"exId", ",", " ", "\"\<InitialCondition\>\""}], "]"}], ",",
            " ", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<MaxGenerations\>\"", " ", "->", " ", "14"}], ",", 
             " ", 
             RowBox[{"\"\<MaxVertices\>\"", " ", "->", " ", "5000"}], ",", 
             " ", 
             RowBox[{"\"\<MaxEvents\>\"", " ", "->", " ", "100000"}]}], 
            "|>"}]}], "]"}], "[", "\"\<StatesList\>\"", "]"}], "]"}]}], ",", 
      " ", 
      RowBox[{"UpTo", "[", "5", "]"}]}], "]"}], "]"}]}], "]"}]}], "Input",Expr\
essionUUID->"04f6ee42-abe0-40af-a63f-4dd5d4230776"],

Cell["Ball volume growth", "Subsection",ExpressionUUID->"ebd6ceaf-97cd-4c79-a9c2-2ccc39d65259"],

Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
