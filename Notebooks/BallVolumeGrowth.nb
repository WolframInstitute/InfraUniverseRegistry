Cell["\<\
Dimension 2.5-3.5, near-flat curvature, at least 1000 vertices.\
\>", "Text",ExpressionUUID->"e97a4027-f0a5-46fa-86e5-a99a89fb9293"],

Cell[BoxData[
 RowBox[{"dataQuery", "[", 
  RowBox[{"Select", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"NumericQ", "[", "#Dimension", "]"}], " ", "&&", " ", 
     RowBox[{"2.5", " ", "<=", " ", "#Dimension", " ", "<=", " ", "3.5"}], 
     " ", "&&", " ", 
     RowBox[{
      RowBox[{"Abs", "[", "#Curvature", "]"}], " ", "<", " ", "0.5"}], " ", "&&",
      " ", 
     RowBox[{"#Vertices", " ", ">=", " ", "1000"}]}], " ", "&"}], "]"}], 
  "]"}]], "Input",ExpressionUUID->"8645ffe8-6333-47e5-82db-46f0d135a4c0"],

